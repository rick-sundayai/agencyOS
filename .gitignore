# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# personal editor settings
.vscode/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# worktrees
.worktrees/
.claude/worktrees/

# local Claude Code settings (personal overrides; launch.json stays tracked)
.claude/settings.local.json

# n8n build output
n8n/dist/

# migration fixtures (real PII, never commit)
scripts/migration/fixtures/

# migration reports (contain real candidate PII — names + JobDiva IDs)
docs/migration-report_*.md

# terraform
**/.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
!*.auto.tfvars.example
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# playwright e2e
/test-results/
/playwright-report/
/e2e/.auth/
